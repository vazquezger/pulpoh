//@version=5
strategy("Trend Following (Surfista) [Pulpoh]", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.05)

// --- Settings ---
// Macro Filter
donchianPeriod = input.int(30, title="Donchian Period (Current breakout)", group="Macro Filter")
volSmaPeriod   = input.int(20, title="Volume SMA Period", group="Macro Filter")
volMultiplier  = input.float(1.2, title="Volume Multiplier", step=0.1, group="Macro Filter")

// Exit
trailPct       = input.float(10.0, title="Trailing Stop (%)", step=0.1, group="Exit")

// --- Calculations ---
// 1. Donchian Channel (Highest High of previous 'donchianPeriod' candles)
// shift(1) equivalent in Pine is history referencing with [1]
highestHigh = ta.highest(high, donchianPeriod)[1]

// 2. Volume Moving Average
volSma = ta.sma(volume, volSmaPeriod)[1]

// 3. Conditions
condBreakout = close > highestHigh
condVolume = volume > (volSma * volMultiplier)

buySignal = condBreakout and condVolume

// --- Execution ---
if (buySignal and strategy.position_size == 0)
    strategy.entry("Long", strategy.long)

// --- Trailing Stop Logic ---
// Convert the % to a decimal (e.g., 10% -> 0.10)
float _trailDecimal = trailPct / 100.0

// Variables to keep track of the trailing stop
var float trailStopPrice = na

// If we are in a long position
if (strategy.position_size > 0)
    // The current stop level given the current close (or high)
    // The previous python code calculates it over the closing prices or highs?
    // A standard trailing stop is (Highest Price since entry) * (1 - trail decimal)
    var float highestPriceSinceEntry = 0.0
    
    if (strategy.position_size[1] == 0)
        // Just entered, initialize highest price
        highestPriceSinceEntry := high
    else
        // Update highest price
        highestPriceSinceEntry := math.max(highestPriceSinceEntry, high)
        
    // Calculate stop limit
    currentStopLimit = highestPriceSinceEntry * (1 - _trailDecimal)
    
    // Update trailing stop price (it can only go up)
    if (na(trailStopPrice))
        trailStopPrice := currentStopLimit
    else
        trailStopPrice := math.max(trailStopPrice, currentStopLimit)
        
    // Trigger stop loss if price (low) crosses below trailing stop
    strategy.exit("Exit Long", from_entry="Long", stop=trailStopPrice)
else
    // Reset variables when not in trade
    trailStopPrice := na

// --- Plotting ---
// Plot the upper breakout band
plot(highestHigh, color=color.blue, title="Donchian Upper Band (Shifted)", style=plot.style_stepline)

// Plot the trailing stop for visual reference (only shows when in trade)
plot(strategy.position_size > 0 ? trailStopPrice : na, color=color.red, title="Trailing Stop", style=plot.style_stepline, linewidth=2)
